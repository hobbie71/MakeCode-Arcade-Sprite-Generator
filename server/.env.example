# Copy to server/.env and fill in real values. Never commit the real .env.
OPENAI_API_KEY=your-openai-api-key
CORS_ORIGINS=["http://localhost:3100","http://localhost:3000"]
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# Per-IP rate limit on the paid endpoints (in-memory, resets on deploy)
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000
