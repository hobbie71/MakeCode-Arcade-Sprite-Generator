{
  "name": "makecode-arcade-sprite-generator",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "bun run --filter '*' --if-present dev",
    "dev:client": "bun run --filter client dev",
    "dev:server": "bun run --filter server dev",
    "test": "bun run --filter '*' --if-present test",
    "typecheck": "bun run --filter '*' --if-present typecheck",
    "lint": "bun run --filter client lint"
  }
}
