{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "css:build": "tailwindcss -c ./tailwind.config.js -i ./src/tailwind.src.css -o ./src/tailwind.gen.css --minify",
    "css:dev": "tailwindcss -c ./tailwind.config.js -i ./src/tailwind.src.css -o ./src/tailwind.gen.css --watch",
    "dev": "bun run css:build && (bun run css:dev & bun run dev-server.ts)",
    "dev:serve": "bun run dev-server.ts",
    "build": "bun run css:build && tsc -b && bun run ./build.ts && cp -R public/* dist/",
    "lint": "eslint .",
    "start": "serve -s dist"
  },
  "dependencies": {
    "@makespritecode/shared": "workspace:*",
    "bad-words": "^4.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.17.0",
    "serve": "^14.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1"
  }
}
