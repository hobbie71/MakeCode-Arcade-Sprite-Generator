# Root .gitignore
node_modules/
dist/
.env
*.log

# TypeScript incremental build info
*.tsbuildinfo

# Fallow cache
.fallow/

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# macOS
.DS_Store

# Claude Code — share the root fallow pre-commit gate; keep all other config local
**/.claude/
!/.claude/
/.claude/*
!/.claude/settings.json
!/.claude/hooks/
/.claude/settings.local.json
